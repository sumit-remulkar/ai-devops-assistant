# LLM Configuration
LLM_PROVIDER=ollama           # ollama | openai | anthropic
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Infrastructure
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://devops:password@localhost:5432/devops_ai

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# App Settings
DRY_RUN=true                  # Set false to execute real remediation
COLLECTION_INTERVAL=15        # Seconds between metric collection
DEBUG=false
SECRET_KEY=change-me-in-production
